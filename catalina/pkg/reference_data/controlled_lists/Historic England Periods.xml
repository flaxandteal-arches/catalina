        <skos:prefLabel xml:lang="en">Tudor</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Dating to the reign of the Tudor monarchs.</skos:scopeNote>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <skos:narrower rdf:resource="http://localhost:8000/986309dc-1a61-4177-9cdf-e21dfbaeffe8"/>
      </skos:Concept>
    </skos:narrower>
    <skos:prefLabel xml:lang="en">Medieval</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The Medieval period or Middle Ages begins with the Norman invasion and ends with the dissolution of the monasteries.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
    <dcterms:identifier>http://www.archesproject.org/fde52573-63e6-457a-90ea-42d8e61d4a7b</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</arches:sortorder>
  </skos:Concept>
