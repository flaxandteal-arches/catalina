  <skos:Concept rdf:about="http://localhost:8000/245a684b-2198-48d3-a620-f843f757af4a">
    <skos:scopeNote xml:lang="en">This dates from the breakdown of Roman rule in Britain to the Norman invasion in 1066 and is to be used for monuments of post Roman, Saxon and Viking date.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
