    <dcterms:identifier>http://www.archesproject.org/245a684b-2198-48d3-a620-f843f757af4a</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/adf6690a-fbf0-41f9-a177-dfacbd3eb058">
    <skos:prefLabel xml:lang="en">Roman</skos:prefLabel>
    <dcterms:identifier>http://www.archesproject.org/adf6690a-fbf0-41f9-a177-dfacbd3eb058</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
    <skos:scopeNote xml:lang="en">Traditionally begins with the Roman invasion in 43AD and ends with the emperor Honorius directing Britain to see to its own defence in 410AD.</skos:scopeNote>
  </skos:Concept>
