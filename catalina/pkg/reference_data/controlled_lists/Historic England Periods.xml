  <skos:Concept rdf:about="http://localhost:8000/c5382b46-7049-4e4a-a51b-d79db123012f">
    <skos:altLabel xml:lang="en">Old Stone Age</skos:altLabel>
    <skos:altLabel xml:lang="en">Paleolithic</skos:altLabel>
    <dcterms:identifier>http://www.archesproject.org/c5382b46-7049-4e4a-a51b-d79db123012f</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Palaeolithic</skos:prefLabel>
    <skos:narrower>
      <skos:Concept rdf:about="http://localhost:8000/c812c32b-7adc-4c37-9c6c-9436fa63eaeb">
        <skos:scopeNote xml:lang="en">The earliest subdivision of the Palaeolithic, or Old Stone Age; when the earliest use of flint tools appears in the current archaeological record. A hunter gatherer society is a defining characteristic.</skos:scopeNote>
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
        <skos:broader rdf:resource="http://localhost:8000/c5382b46-7049-4e4a-a51b-d79db123012f"/>
        <dcterms:identifier>http://www.archesproject.org/c812c32b-7adc-4c37-9c6c-9436fa63eaeb</dcterms:identifier>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <skos:prefLabel xml:lang="en">Lower Palaeolithic</skos:prefLabel>
      </skos:Concept>
    </skos:narrower>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</arches:sortorder>
    <skos:scopeNote xml:lang="en">The period once referred to as the Old Stone Age. It is defined by the practice of hunting and gathering and the use of chipped flint tools. This period is usually divided up into the Lower, Middle and Upper Palaeolithic.</skos:scopeNote>
    <skos:narrower>
      <skos:Concept rdf:about="http://localhost:8000/6f9b6a55-da93-45ad-abad-300e452694f7">
        <dcterms:identifier>http://www.archesproject.org/6f9b6a55-da93-45ad-abad-300e452694f7</dcterms:identifier>
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</arches:sortorder>
        <skos:broader rdf:resource="http://localhost:8000/c5382b46-7049-4e4a-a51b-d79db123012f"/>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <skos:scopeNote xml:lang="en">The second subdivision of the Palaeolithic or Old Stone Age. Characterized by the fine flake tools of the Mousterian tradition and economically by a hunter gatherer society.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Middle Palaeolithic</skos:prefLabel>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="http://localhost:8000/30946005-ba27-4d96-b6de-cc79434f4023">
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <skos:broader rdf:resource="http://localhost:8000/c5382b46-7049-4e4a-a51b-d79db123012f"/>
        <skos:scopeNote xml:lang="en">The third and last subdivision of the Palaeolithic or Old Stone Age; characterized by the development of projectile points made from bony materials and the development of fine blade flint tools.</skos:scopeNote>
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
        <dcterms:identifier>http://www.archesproject.org/30946005-ba27-4d96-b6de-cc79434f4023</dcterms:identifier>
        <skos:prefLabel xml:lang="en">Upper Palaeolithic</skos:prefLabel>
      </skos:Concept>
    </skos:narrower>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/15a021f9-000e-4fd4-b92d-6872dbbdc56b">
    <skos:scopeNote xml:lang="en">The second subdivision of the Iron Age.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
    <skos:broader>
      <skos:Concept rdf:about="http://localhost:8000/6ba234ef-5948-43b8-b347-cfe779aeb79c">
        <skos:narrower rdf:resource="http://localhost:8000/eedfc939-272d-42b4-b96e-cb681efb6a3e"/>
        <skos:narrower rdf:resource="http://localhost:8000/8764dd25-6d36-4be4-ae24-40088236c0e9"/>
        <skos:prefLabel xml:lang="en">Iron Age</skos:prefLabel>
        <skos:narrower rdf:resource="http://localhost:8000/15a021f9-000e-4fd4-b92d-6872dbbdc56b"/>
        <skos:scopeNote xml:lang="en">This period follows on from the Bronze Age and is characterized by the use of iron for making tools and monuments such as hillforts and oppida. The Iron Age is taken to end with the Roman invasion.</skos:scopeNote>
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</arches:sortorder>
        <dcterms:identifier>http://www.archesproject.org/6ba234ef-5948-43b8-b347-cfe779aeb79c</dcterms:identifier>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
      </skos:Concept>
    </skos:broader>
    <skos:prefLabel xml:lang="en">Middle Iron Age</skos:prefLabel>
    <dcterms:identifier>http://www.archesproject.org/15a021f9-000e-4fd4-b92d-6872dbbdc56b</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/fde52573-63e6-457a-90ea-42d8e61d4a7b">
