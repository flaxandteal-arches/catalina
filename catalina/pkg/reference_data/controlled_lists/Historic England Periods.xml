        <skos:narrower rdf:resource="http://localhost:8000/9032ba54-5b96-4dde-9f60-f6dd967e8e4b"/>
        <dcterms:identifier>http://www.archesproject.org/e972997b-1ed0-4b3f-af4c-7f083307ed57</dcterms:identifier>
        <skos:scopeNote xml:lang="en">Dating to the reign of the Hanoverian kings and queens.    </skos:scopeNote>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <skos:prefLabel xml:lang="en">Hanoverian</skos:prefLabel>
      </skos:Concept>
    </skos:broader>
    <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
    <skos:scopeNote xml:lang="en">Dating to or characteristic of the reigns of any of the first four kings of Great Britain called George.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Georgian</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
