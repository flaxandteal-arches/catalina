  <skos:Concept rdf:about="http://localhost:8000/c43fbe87-3763-47ca-a336-38f2eca94b22">
    <skos:prefLabel xml:lang="en">Mesolithic</skos:prefLabel>
    <dcterms:identifier>http://www.archesproject.org/c43fbe87-3763-47ca-a336-38f2eca94b22</dcterms:identifier>
    <skos:scopeNote xml:lang="en">The Middle Stone Age, falling between the Palaeolithic and the Neolithic; marks the beginning of a move from a hunter gatherer society towards food producing society.</skos:scopeNote>
    <skos:narrower>
      <skos:Concept rdf:about="http://localhost:8000/c5e4ae8d-9478-45e6-b934-c1fb3ab33d8f">
        <dcterms:identifier>http://www.archesproject.org/c5e4ae8d-9478-45e6-b934-c1fb3ab33d8f</dcterms:identifier>
        <skos:prefLabel xml:lang="en">Early Mesolithic</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The earliest subdivision of the Mesolithic, or Middle Stone Age.</skos:scopeNote>
        <skos:broader rdf:resource="http://localhost:8000/c43fbe87-3763-47ca-a336-38f2eca94b22"/>
        <skos:inScheme rdf:resource="http://localhost:8000/ce5a1ebb-f1ce-42ed-9c43-14cb8637241f"/>
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
