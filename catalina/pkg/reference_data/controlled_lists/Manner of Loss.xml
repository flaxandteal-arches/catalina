    <skos:prefLabel xml:lang="en">Spontaneous Combustion</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Ignition from within rather than through external forces; frequently associated with cargoes of organic material such as manure, owing to an internal rise in temperature of the cargo itself.</skos:scopeNote>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220">
        <dcterms:title>Manner of Loss</dcterms:title>
      </skos:ConceptScheme>
    </skos:inScheme>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">35</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/99fa8f02-f8d1-3015-a179-8da98a28c953">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">33</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5216</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A vessel which has been deliberately scuttled using explosive charges.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Scuttling Charges</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/cfb016a3-7634-3b78-b4a2-ac4f4771c747">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Capsized</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A vessel lost having overturned due to severe weather or shifting cargo.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/558</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/bada0bc4-3e9f-3a42-abd8-bdf2f5d884af">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5215</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">39</arches:sortorder>
    <skos:prefLabel xml:lang="en">Vandalism</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">Acts of vandalism, or deliberate damage by owner or other parties, which result in the `Constructive Total Lossï¿½ (CTL) of vessel, or contributes to CTL of an abandoned vessel.</skos:scopeNote>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/1111eb4c-bd09-3a16-8f95-109fe86b87b3">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5238</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">40</arches:sortorder>
    <skos:prefLabel xml:lang="en">Washed Up</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">Use only for fragmentary wreckage washed up at the time of loss or subsequently: but not for complete hulls for which STRANDED or another appropriate manner of loss should be used.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/036b2f3f-746a-3c26-8ddc-753666b96232">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">Loss of a vessel or aircraft primarily due to fire.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/557</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Burnt</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/499edd53-748f-3768-80a0-4aa66ccdb551">
    <skos:prefLabel xml:lang="en">Partially Recovered</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">29</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">Use where a section of the vessel has been recovered from where she lies, either at the time or subsequently, leaving behind substantial remains (unlike RECOVERED, where the entire vessel has been removed from the site).</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5213</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/d0d3b35f-144b-315a-9570-de0febc171f3">
    <skos:scopeNote xml:lang="en">Use where an entire, wrecked or incapacitated, craft has been recovered or salvaged, possibly leaving debris or other evidence of its presence at the wreck or crash site. If part of the wreck remains on the seabed use PARTIALLY RECOVERED.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">31</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5065</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Recovered</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/a4908cf6-258d-34b7-8968-4b4e4bee4b8e">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">The loss of a craft due to structural or engine failure. In the case of loss resulting from the malfunction of navigational or operational apparatus, use INSTRUMENT FAILURE.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Mechanical Failure</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/1424</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">27</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/050cb612-33db-3580-8c6c-86dad535b7a6">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/561</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">A vessel or aircraft lost due to an accidental explosion.  Do not use for losses caused by deliberate action.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:prefLabel xml:lang="en">Explosion</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">17</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/9af0feae-a360-3a67-b6a7-5b4b6235c357">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/1425</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">34</arches:sortorder>
    <skos:prefLabel xml:lang="en">Shot Down</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An aircraft lost due to offensive action. Includes air-to-air and ground-to-air combat. For Vessels use GUN ACTION.</skos:scopeNote>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/cd61b0e0-8c4e-38a4-ae9d-91b120578d9f">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:prefLabel xml:lang="en">Crashed</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</arches:sortorder>
    <skos:scopeNote xml:lang="en">An aircraft which has been damaged beyond repair due to a collision with the ground or sea.</skos:scopeNote>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/1423</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/5d8c9d44-c282-350e-87e7-ce27928e2502">
    <skos:prefLabel xml:lang="en">Enemy Action</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5197</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">Loss due to cumulative damage sustained during acts of warfare, capture, piracy, privateering etc. Use in instances where a more specific manner of loss (e.g. SCUTTLED, GUN ACTION) cannot be assigned.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/edc2c56b-cd3f-3714-8df4-da6bce98c763">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">25</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5217</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Lightning Strike</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A vessel which has damaged by a lightning strike and subsequently lost.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/22283369-35d1-37ba-b973-4b51ec99ace0">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">38</arches:sortorder>
    <skos:prefLabel xml:lang="en">Used In Construction</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">Reuse of timbers or hull of a vessel in construction. For example sinking of hulks as harbour foundations or recycling of timbers in domestic contexts.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5240</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/beb2314d-0e07-3d21-bf47-5b12467440a5">
    <skos:prefLabel xml:lang="en">Beached</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A vessel that is deliberately run or dragged up the beach to save cargo and or crew. Do not use if the vessel is refloated.</skos:scopeNote>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/553</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/23271a3b-4dae-3cde-aa6b-57930429e762">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/1422</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">An aircraft which has been forced to land on the sea in an emergency.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Ditched</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/e4ea902e-e377-37df-a1d4-a4e39353dc94">
    <skos:scopeNote xml:lang="en">Loss due to action of self propelled submerged missile.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/573</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Torpedoed</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">37</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/c0d1c7da-a07d-3101-bbbc-97f2136b042a">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/572</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">36</arches:sortorder>
    <skos:scopeNote xml:lang="en">A vessel which runs aground and does not get off.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Stranded</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/838709c0-cd6a-3341-b502-eb72aa57f12e">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Collision</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Loss of a vessel or aircraft through accidental contact with another or a structure. Do not use when contact is with natural feature or rocky shore.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/559</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/e65f89db-e9cc-39b4-a52f-2613f7ad190b">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/556</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</arches:sortorder>
    <skos:scopeNote xml:lang="en">A vessel which has been dismantled for the purpose of removal from the shore after stranding.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Broken Up</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/7469073f-7074-3b77-8738-92e4d926c7b9">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">24</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/566</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:prefLabel xml:lang="en">Leaked</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Ingress of water through damage or defects in the hull. Double-index with any cause, were known, e.g. COLLISION, and consequence, were known, e.g. BEACHED, FOUNDERED.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/770ad9c6-f271-3441-9cb4-4c4e0debeba3">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">22</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5220</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Internal Explosion</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Loss of a vessel or aircraft due to an explosion caused by its own armament or cargo.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/da972b53-8573-3b71-8449-3da4935b1eb5">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">19</arches:sortorder>
    <skos:scopeNote xml:lang="en">Loss of a vessel due to running aground and subsequently refloating before final loss.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Grounded</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/563</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/767fb6aa-37b8-398b-9b19-4af2e2761680">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/560</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Loss of vessel due to deployment of explosive charges set to detonate at a predetermined depth.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Depth Charged</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/00580253-a8a1-3b32-9f43-4c3d7f7a63dd">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/568</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">Loss due to action of free floating or tethered explosive device set to explode on contact with or in proximity to a vessel.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Mined</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">28</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/401dd48e-f4d7-3e76-bea6-056171ac55a8">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</arches:sortorder>
    <skos:scopeNote xml:lang="en">Damaged, usually by weather or warfare, to such an extent that the vessel is in severe or imminent danger of being lost; i.e. a pre-existing condition of the vessel which contributes to the final wrecking event.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/837</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Distressed</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/4972ee65-a3b4-3d06-bc9f-de15197b5576">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:prefLabel xml:lang="en">Ramming</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/569</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Deliberate collision with another vessel in order to inflict damage.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/84baa717-4888-3a00-bb12-ef6c5bef9dcc">
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">21</arches:sortorder>
    <skos:scopeNote xml:lang="en">Loss of a craft, especially aircraft, resulting from the malfunction of registering or measuring apparatus vital to its navigation or operation. In the case of structural or engine failure use MECHANICAL FAILURE.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5195</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Instrument Failure</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/56f0d962-ebef-34a0-b5e3-5ffc9713ac20">
    <skos:scopeNote xml:lang="en">A vessel withdrawn from active use and awaiting disposal or reuse.  Vessel subsequently becomes derelict.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Laid Up</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/565</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">23</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/b30dbb4d-fe49-32dd-9ac3-97ee794a2c46">
    <skos:prefLabel xml:lang="en">Bombed</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">A vessel lost due to aerial bombardment.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/554</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/2b9f867d-bd3b-315f-baff-cd15b13b0ead">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:prefLabel xml:lang="en">Gun Action</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/564</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</arches:sortorder>
    <skos:scopeNote xml:lang="en">Loss of a vessel due to bombardment from ship, shore or submarine. For Aircraft use SHOT DOWN.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/66580a90-7afb-3047-9849-1d3d9ca6813f">
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Beyond Repair</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Use for 'constructive total loss' (CTL) or where a vessel is abandoned because she is beyond repair or has become so after abandonment, which may include acts of vandalism.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5212</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/fd2fe54f-c431-3848-869a-8ffe97b26df9">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">41</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">A vessel which comes ashore and breaks up immediately due to severe weather.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Wrecked</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/574</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/314bae16-9857-3970-af12-38276c22db52">
    <skos:scopeNote xml:lang="en">Judged as irreparable or no longer seaworthy following a wrecking incident (from which the vessel may have been recovered) or a difficult voyage: a term with legal force indicating that the vessel is unfit for service.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Condemned</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5198</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/d6fe83f7-58d3-31ad-bc3c-fd09bd864bf6">
    <skos:prefLabel xml:lang="en">Foundered</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/562</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">18</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">A vessel that has sunk at sea: Double-index with background cause were known, e.g. LEAKED, COLLISION.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/7df0a701-7bfc-3d04-8ae5-57d564b22e47">
    <skos:prefLabel xml:lang="en">Dispersed</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5129</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">For use when a vessel, already lost through other causes, is dismantled or dispersed by means of explosives to render it harmless to other shipping.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/0f013352-1d62-3539-95a7-c67da61a726e">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">26</arches:sortorder>
    <skos:scopeNote xml:lang="en">A vessel or aircraft lost at sea, cause unknown.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/567</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Lost</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/0f170590-1333-3540-bc0a-3df539817961">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/555</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Stoving in or fracturing of lowest part of vessel's hull.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Bilged</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/3924e300-a6fe-3258-ab0a-940bdb5252ee">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/5214</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</arches:sortorder>
    <skos:prefLabel xml:lang="en">Back Broken</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <skos:scopeNote xml:lang="en">Use when the vessel splits in two due to stresses on her frame where she lies unsupported either amidships or at the ends, typically after stranding, although this may also happen in similar conditions on the seabed after foundering.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/57a8472c-1a40-305e-b1df-d1d5462f4fea">
    <skos:prefLabel xml:lang="en">Scuttled</skos:prefLabel>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:scopeNote xml:lang="en">Deliberate sinking of a vessel, e.g. to prevent capture or to act as a blockship.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">32</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/571</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/ec5863b1-3c36-3545-926c-72773ea5d3df">
    <skos:scopeNote xml:lang="en">Refers to the abandonment of a vessel at sea due to its becoming unseaworthy.  Do not use for vessels abandoned having run aground. For aircraft use DITCHED.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/78/concepts/552</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/24edabea-f23d-3a67-b22a-4cc421ef4dd2"/>
    <skos:prefLabel xml:lang="en">Abandoned</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/757832dd-028d-444a-b2f2-8742b6d43220"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
  </skos:Concept>
</rdf:RDF>
