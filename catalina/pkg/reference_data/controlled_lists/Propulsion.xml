    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
    <skos:scopeNote xml:lang="en">Use for a man-powered watercraft operated by wooden oars.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/4e7827a2-cb42-448c-bcdc-a6df93409b8e"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/0978ff2f-3719-44b4-afc7-574224d9aaae">
