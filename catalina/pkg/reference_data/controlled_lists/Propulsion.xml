    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</arches:sortorder>
    <skos:scopeNote xml:lang="en">Use for craft, such as logboats and punts, powered by pushing a pole against the riverbed in inland waters.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/2cdd3620-a90e-4e8a-94f7-f299c5a9efea">
