    <skos:prefLabel xml:lang="en">Towed</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Use for craft built with no engines or masts and designed to be towed by another craft.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/4e7827a2-cb42-448c-bcdc-a6df93409b8e"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</arches:sortorder>
  </skos:Concept>
