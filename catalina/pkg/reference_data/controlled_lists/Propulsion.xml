    <skos:scopeNote xml:lang="en">Use for a man-powered watercraft propelled by a paddle, such as logboats and canoes.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/119ef7c1-fd1e-4d14-95e6-1b5a0b23f26f">
    <dcterms:identifier>http://localhost:8000/119ef7c1-fd1e-4d14-95e6-1b5a0b23f26f</dcterms:identifier>
