<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:arches="http://localhost:8000/"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <skos:Concept rdf:about="http://localhost:8000/7af43b06-5919-32ce-913f-ed7035348130">
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b">
        <dcterms:title>Dating Techniques</dcterms:title>
      </skos:ConceptScheme>
    </skos:inScheme>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142131</dcterms:identifier>
    <skos:scopeNote xml:lang="en">The measuring of annual tree-ring growth shown by most tree species in temperated regions. Regional chronoliges are required to date any particular piece of wood, the longest of which, for Germany, works for the present to approximately 14,000 yrs ago.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</arches:sortorder>
    <skos:prefLabel xml:lang="en">Dendrochronology</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/840a7a07-49e4-3593-90fa-ac0c1e43dc83">
    <skos:scopeNote xml:lang="en">The use of ash and tephra deposits characteristic of single known-date volcanic eruptions to date stratigraphic sequences.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Tephrochronology</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142202</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/0d58e95a-7623-3afb-9c3a-6c3114b42561">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142104</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Measures the remanent magnetisation direction of magnetic minerals. Useful for dating fired structures, in-situ since their last firing, and for sediments settling from non turbulent water bodies. In the UK, calibration data extends back to 1000BC.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Archaeomagnetism</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/c63a8fae-15c5-32bb-a629-1ebb3627ea5d">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142100</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Amino Acid Racemisation</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The measurement of chemical alterations in the amino acids in protein molecules from bones, shells and teeth. Date range can be between 1,000 and several million years.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/31a10bcc-2b83-34b1-8057-5df78fdcf6eb">
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Oxygen Isotope Analysis</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The use of oxygen (O) isotope ratios in ice or ocean sediment cores to date global environmental change.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142178</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/8033a56a-7792-3784-92da-51b3b369cac0">
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142107</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Biostratigraphy</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A technique in which the date is deduced from the presence of fauna and/or flora considered to be characteristic of a given peirod of time or that gives and indication of a probable date.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/a132813d-3591-3a4c-a825-7dc832f29530">
    <skos:prefLabel xml:lang="en">Lead Isotope Dating</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142155</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:scopeNote xml:lang="en">A technique which uses the measurement of decay in radioactive lead (Pb) isotopes to determine a date. Useful for sediments and lead-based paints between 1 and 400 years old.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/1c49e0c6-eedb-3c64-bf6a-e8c6f69af612">
    <skos:prefLabel xml:lang="en">Obsidian Hydration</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</arches:sortorder>
    <skos:scopeNote xml:lang="en">A technique used to date obsidian (volcanic glass) of all ages and is thus not commonly used in the UK.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142176</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/719fe1be-291b-38dc-90ac-743e6abc403b">
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:scopeNote xml:lang="en">The measurement of trapped electrons by exposure to high-frequency electromagnetic radiation. A useful technique for dating tooth enamel, shells, coral and calcite form 5,000-1,000,000 years old.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142136</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Electron Spin Resonance</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/436809b5-dc4d-37f8-baff-74cd0c909212">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142140</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A technique for the dating of damage tracks in volcanic materials caused by the fissioning of decaying radioactive uranium (U) isotopes. Useful in samples more than 50,000 years old.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</arches:sortorder>
    <skos:prefLabel xml:lang="en">Fission Track Analysis</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/cdcc4871-f3f2-37b3-9cdd-7c4a6b508a91">
    <skos:altLabel xml:lang="en">Carbon 14 Dating</skos:altLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142188</dcterms:identifier>
    <skos:altLabel xml:lang="en">Carbon Dating</skos:altLabel>
    <skos:scopeNote xml:lang="en">The measurement of the ratio of the radioactive Carbon 14 (C-14) isotope and non-radioactive carbon isotopes. Useful for dating organic materials such as wood and bone between 500 and 45,000 years old.</skos:scopeNote>
    <skos:altLabel xml:lang="en">C14 Dating</skos:altLabel>
    <skos:prefLabel xml:lang="en">Radiocarbon Dating</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/c61558c5-d6ec-3f5f-af47-0152dfdd349f">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142212</dcterms:identifier>
    <skos:scopeNote xml:lang="en">The measurement of the decay of radioactive uranium (U) isotopes. Particularly useful for dating calcite and sometimes bone, tooth and shell up to 70,000 years old.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Uranium Series Dating</skos:prefLabel>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/69c7a05e-2dfe-36ad-ab6a-bae85d6c3e45">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142142</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Fluorine, Uranium And Nitrogen Tests</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A relative dating technique for assessing bones from the same deposit. Often used to check for contemporaneity of bones selected for radiocarbon dating or to check for hoaxes such as the Piltdown Man.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/2c167ba9-b28b-3f1b-bdd4-a2d21c4af186">
    <skos:scopeNote xml:lang="en">A dating technique for the founding of individual populations based on the assumption of steady rates of mutation in mitochondrial DNA. Sometimes used to produce dates for stratigraphic layers containing fossil specimens of populations.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Mitochondrial DNA</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142170</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/c9dec2eb-8691-3852-8019-972210e4ce89">
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Potassium Argon Dating</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</arches:sortorder>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142187</dcterms:identifier>
    <skos:scopeNote xml:lang="en">The measurement of the ratio of a radioactive potassium (K) isotope and the argon (Ar) gas produced as a by-product of its decay. Useful for dating volcanic material older than 1,000 years.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/6f483b29-cb10-390f-8eb6-d7762a855c54">
    <skos:altLabel xml:lang="en">IRSL Dating</skos:altLabel>
    <skos:broader>
      <skos:Concept rdf:about="http://localhost:8000/2307ccd5-5d30-3593-8d29-bf6426ff4974">
        <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</arches:sortorder>
        <skos:narrower rdf:resource="http://localhost:8000/7d1d2293-db33-3dce-8e9c-fa0f14ad9f44"/>
        <skos:narrower rdf:resource="http://localhost:8000/c8057624-cec1-3a1f-b84e-fec174265d40"/>
        <skos:prefLabel xml:lang="en">Luminescence Dating</skos:prefLabel>
        <skos:narrower rdf:resource="http://localhost:8000/6f483b29-cb10-390f-8eb6-d7762a855c54"/>
        <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/144511</dcterms:identifier>
        <skos:scopeNote xml:lang="en">A range of techniques that use the build up of charge stored within a crystalline material to estimate its age</skos:scopeNote>
      </skos:Concept>
    </skos:broader>
    <skos:prefLabel xml:lang="en">Infra-Red Stimulated Luminescence</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The light emitted from sedimentary minerals or mineral inclusions in bricks when stimulated in the laboratory by infrared light. Used to date samples up to 250,000 years old; especially appropriate for geological sediments containing feldspars</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
    <skos:altLabel xml:lang="en">IRSL</skos:altLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142151</dcterms:identifier>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/7d1d2293-db33-3dce-8e9c-fa0f14ad9f44">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142177</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Optically Stimulated Luminescence</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The light emitted from sedimentary minerals or mineral inclusions in bricks when stimulated in the laboratory by light of a different wavelength. Used to date samples up to 250,000 years old; especially appropriate for geological sediments.</skos:scopeNote>
    <skos:altLabel xml:lang="en">OSL Dating</skos:altLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</arches:sortorder>
    <skos:broader rdf:resource="http://localhost:8000/2307ccd5-5d30-3593-8d29-bf6426ff4974"/>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/c8057624-cec1-3a1f-b84e-fec174265d40">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
    <skos:inScheme rdf:resource="http://localhost:8000/c6a5328f-cae7-4984-a446-6f89edbeb49b"/>
    <skos:prefLabel xml:lang="en">Thermoluminescence</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The measurement of the light emitted from sedimentary minerals, mineral inclusions in bricks, burnt flint or unburnt calcite when they are heated. The signal relates to their prior exposure to radioactivity. Used to date samples up to 500,000 years old.</skos:scopeNote>
    <skos:altLabel xml:lang="en">TL Dating</skos:altLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/560/concepts/142203</dcterms:identifier>
    <skos:broader rdf:resource="http://localhost:8000/2307ccd5-5d30-3593-8d29-bf6426ff4974"/>
  </skos:Concept>
</rdf:RDF>
