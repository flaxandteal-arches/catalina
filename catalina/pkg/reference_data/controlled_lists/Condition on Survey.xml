<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:arches="http://localhost:8000/"
>
  <skos:Concept rdf:about="http://localhost:8000/c95dcfab-9e66-4d60-8f29-cab6303a08e7">
    <dcterms:identifier>http://localhost:8000/c95dcfab-9e66-4d60-8f29-cab6303a08e7</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Damage to the majority or all of the features of interest is apparent, or significant features of interest are missing. Some features of interest remain. Active damage apparent (e.g. for buildings water penentration, rot etc).</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Poor</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</arches:sortorder>
    <skos:inScheme>
      <skos:ConceptScheme rdf:about="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7">
        <dcterms:title>Condition on Survey</dcterms:title>
      </skos:ConceptScheme>
    </skos:inScheme>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/738ba472-2110-4686-aeb8-098943331ec1">
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
    <skos:prefLabel xml:lang="en">Uncertain</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Features of interest are not surveyable at the time of the survey, e.g. obscured by cloud-cover, vegetation, ongoing building work etc. or the monument could not be located.</skos:scopeNote>
    <dcterms:identifier>http://localhost:8000/738ba472-2110-4686-aeb8-098943331ec1</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/1ea27803-00c7-4b43-8cad-d2b531bede13">
    <skos:prefLabel xml:lang="en">Fair</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Some damage or part destruction of features of interest apparent, or the features of interest are obscured by more recent additions/alterations. For buildings, indicates structurally sound, but in need of minor repair.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
    <dcterms:identifier>http://localhost:8000/1ea27803-00c7-4b43-8cad-d2b531bede13</dcterms:identifier>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/8cc5c3b8-11f8-44a2-b509-f50e5c3a2f36">
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</arches:sortorder>
    <skos:prefLabel xml:lang="en">Good</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
    <dcterms:identifier>http://localhost:8000/8cc5c3b8-11f8-44a2-b509-f50e5c3a2f36</dcterms:identifier>
    <skos:scopeNote xml:lang="en">All or nearly all features of interest are well preserved for the period they represent and are clear at the time of survey. No sign of active damage.</skos:scopeNote>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/06c3797c-a437-4281-803e-cb03e598c80e">
    <dcterms:identifier>http://localhost:8000/06c3797c-a437-4281-803e-cb03e598c80e</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Infilled</skos:prefLabel>
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
    <skos:scopeNote xml:lang="en">Feature exists but has been infilled.</skos:scopeNote>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</arches:sortorder>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/e100c7da-365b-45cf-8927-4a88322aeda8">
    <skos:prefLabel xml:lang="en">Very Bad</skos:prefLabel>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</arches:sortorder>
    <skos:scopeNote xml:lang="en">All features of interest are damaged beyond use for survey purposes or are missing. For buildings, this indicates structural failure or evident instability, loss of significant areas of roofing, or a major fire or other disaster.</skos:scopeNote>
    <dcterms:identifier>http://localhost:8000/e100c7da-365b-45cf-8927-4a88322aeda8</dcterms:identifier>
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
  </skos:Concept>
  <skos:Concept rdf:about="http://localhost:8000/10acc7ed-4949-427e-b8c1-4e22e3537c6e">
    <skos:inScheme rdf:resource="http://localhost:8000/7a877d45-7015-49a6-b5ee-c4f7d4e137c7"/>
    <arches:sortorder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</arches:sortorder>
    <skos:scopeNote xml:lang="en">All features of interest have been destroyed. No further information can be gained from future investigation of the site. Includes demolished buildings unless foundations, basements etc exist which are of interest, for which use very bad.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Destroyed</skos:prefLabel>
    <dcterms:identifier>http://localhost:8000/10acc7ed-4949-427e-b8c1-4e22e3537c6e</dcterms:identifier>
  </skos:Concept>
</rdf:RDF>
